{
	"name": "sileo-vue",
	"version": "0.1.5",
	"description": "An opinionated, physics based toast notification library for vue.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/hiaaryan/sileo.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/sileo-vue.js"
		},
		"./styles.css": "./dist/sileo-vue.css"
	},
	"main": "./dist/sileo-vue.js",
	"module": "./dist/sileo-vue.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"type-check": "vue-tsc --noEmit -p tsconfig.app.json"
	},
	"peerDependencies": {
		"vue": ">=3.4"
	},
	"dependencies": {
		"motion-v": "^2.3.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@vitejs/plugin-vue": "^5.2.1",
		"typescript": "~5.7.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.5.4",
		"vue": "^3.5.39",
		"vue-tsc": "^2.2.0"
	}
}
